# Hackers Ai Everywhere - Environment Variables
# Powered by Cloudflare Workers AI 🚀
# Set these in your environment variables.

PORT=10000
SESSION_SECRET=change_me_session_secret
JWT_SECRET=change_me_jwt_secret

# Supabase Connection
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Cloudflare Workers AI (REQUIRED — set these in Render env vars)
# Single key:
CF_ACCOUNT_ID=
CF_API_TOKEN=
# Multi-key support: add up to 50 pairs (CF_ACCOUNT_ID_1..50 + CF_API_TOKEN_1..50)
# The system auto-rotates through all available keys.
# Example:
# CF_ACCOUNT_ID_1=99ba65295e6aed123ae42af29976d39b
# CF_API_TOKEN_1=cfut_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CF_ACCOUNT_ID_2=another_account_id
# CF_API_TOKEN_2=cfut_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# Browserless.io API Key (for real web browsing with screenshots)
BROWSERLESS_API_KEY=

# Flutterwave Payment Keys
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPTION_KEY=

# Pre-configured Flutterwave payment links
FLW_BASIC_LINK=
FLW_PRO_LINK=

# Trial period in days
TRIAL_DAYS=2
# Admin panel password
ADMIN_PANEL_PASSWORD=change_me